<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.transaction.mybatis.mapper.AccountMapper">

    <resultMap id="accountResultMap" type="com.example.transaction.entity.Account">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="balance" column="balance"/>
        <result property="accountType" column="account_type"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findById" resultMap="accountResultMap">
        SELECT * FROM t_account WHERE id = #{id}
    </select>

    <select id="findByUserId" resultMap="accountResultMap">
        SELECT * FROM t_account WHERE user_id = #{userId}
    </select>

    <select id="findAll" resultMap="accountResultMap">
        SELECT * FROM t_account
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_account (user_id, balance, account_type) VALUES (#{userId}, #{balance}, #{accountType})
    </insert>

    <update id="updateBalance">
        UPDATE t_account SET balance = balance + #{amount} WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM t_account WHERE id = #{id}
    </delete>

</mapper>
