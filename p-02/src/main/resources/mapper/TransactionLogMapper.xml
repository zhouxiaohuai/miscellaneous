<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.transaction.mybatis.mapper.TransactionLogMapper">

    <resultMap id="logResultMap" type="com.example.transaction.entity.TransactionLog">
        <id property="id" column="id"/>
        <result property="operation" column="operation"/>
        <result property="status" column="status"/>
        <result property="detail" column="detail"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_transaction_log (operation, status, detail) VALUES (#{operation}, #{status}, #{detail})
    </insert>

    <select id="findAll" resultMap="logResultMap">
        SELECT * FROM t_transaction_log ORDER BY create_time DESC
    </select>

</mapper>
